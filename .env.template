# ========================================
# API-TENNIS (obligatoria para partidos y cuotas)
# ========================================
# Obtén tu API key en: https://api-tennis.com
# Partidos, cuotas, resultados y rankings usan esta API.
API_TENNIS_API_KEY=tu_api_key_api_tennis

# The Odds API: no se usa en este proyecto (las cuotas vienen de API-Tennis).
# ODDS_API_KEY=opcional_no_usada

# ========================================
# ALERTAS POR EMAIL (OPCIONAL)
# ========================================

# Habilitar/deshabilitar alertas por email
EMAIL_ENABLED=false

# Configuración SMTP (Gmail)
# Para Gmail, necesitas crear una "App Password":
# https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Credenciales de email
EMAIL_ADDRESS=tu@email.com
EMAIL_PASSWORD=tuapppasswordgmail

# Destinatario de alertas
EMAIL_RECIPIENT=tu@email.com

# ========================================
# FUENTE DE DATOS TML (OPCIONAL)
# ========================================
# Base URL para descargar CSVs de partidos por año ({year}.csv).
# Por defecto: https://stats.tennismylife.org/data (datos actualizados).
# TML_BASE_URL=https://stats.tennismylife.org/data

# ========================================
# PREDICCIÓN / BACKTESTING (OPCIONAL)
# ========================================
# Mismo proceso que backtesting_produccion_real_completo.py
# Valores por defecto ya están en el código; solo define si quieres cambiar.

# EV mínimo para recomendar apuesta (default 0.10 = 10%)
# EV_THRESHOLD=0.10

# Bankroll de referencia para calcular stake (default 1000)
# BANKROLL_INICIAL=1000

# Kelly fracción (default 0.05 = 5%)
# KELLY_FRACTION=0.05

# Mínimo stake en € (default 5)
# MIN_STAKE_EUR=5

# Máximo % del bankroll por apuesta (default 0.10 = 10%)
# MAX_STAKE_PCT=0.10
